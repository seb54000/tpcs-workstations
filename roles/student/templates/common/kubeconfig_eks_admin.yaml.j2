{% set eks_clusters = (tf_vars.eks_clusters.value if (tf_vars.eks_clusters is defined and tf_vars.eks_clusters.value is defined) else {}) %}
{% set cluster_names = eks_clusters.keys() | list | sort %}
{% set admin_tokens = (hostvars['localhost'].eks_admin_tokens if (hostvars['localhost'].eks_admin_tokens is defined) else {}) %}
apiVersion: v1
kind: Config
preferences: {}
clusters:
{% for cluster_key in cluster_names %}
  - name: "{{ cluster_key }}"
    cluster:
      server: "{{ eks_clusters[cluster_key].endpoint }}"
      certificate-authority-data: "{{ eks_clusters[cluster_key].certificate_authority_data }}"
{% endfor %}
users:
{% for cluster_key in cluster_names %}
  - name: "{{ cluster_key }}-admin-user"
    user:
      token: "{{ admin_tokens[cluster_key] | default('') }}"
{% endfor %}
contexts:
{% for cluster_key in cluster_names %}
  - name: "{{ cluster_key }}-admin"
    context:
      cluster: "{{ cluster_key }}"
      user: "{{ cluster_key }}-admin-user"
{% endfor %}
current-context: "{{ (cluster_names[0] ~ '-admin') if (cluster_names | length) > 0 else '' }}"
