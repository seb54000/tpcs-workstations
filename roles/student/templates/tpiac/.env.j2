{% raw %}#{% endraw %} aws console password : {{ tf_vars.tpiac_users.value[ ansible_hostname[-2:] | int ].user_pwd }}

{% raw %}#{% endraw %} ami-id (noble amd64) for region : {{ student_tp_vars.tpiac.aws.region_for_apikey }} ==> {{ student_tpiac_ami_for_template_with_regions_list[(student_count_number_2digits | int) % (student_tpiac_ami_for_template_with_regions_list | length)] | default() }} (https://cloud-images.ubuntu.com/locator/ec2/)

# TP IaC AWS credentials are configured in the default AWS CLI profile:
# - /home/{{ ansible_hostname }}/.aws/credentials
# - /home/{{ ansible_hostname }}/.aws/config
#
# They are kept here as a memo for the TP:
# aws_access_key_id = {{ tf_vars.tpiac_users.value[ ansible_hostname[-2:] | int ].user_apikey }}
# aws_secret_access_key = {{ tf_vars.tpiac_users.value[ ansible_hostname[-2:] | int ].user_apikey_secret }}
# region = {{ student_tp_vars.tpiac.aws.region_for_apikey }}

# These Terraform variables are also written to demoboard/terraform/tpiac.auto.tfvars.
# Sourcing this file is only kept as a compatibility helper.
export TF_VAR_ami={{ student_tp_vars.tpiac.aws.ami_id }}
export TF_VAR_type=t3.micro
export TF_VAR_instance_details='{"count":2,"image_id":"{{ student_tp_vars.tpiac.aws.ami_id }}","type":"t3.micro"}'
export TF_VAR_ssh_key_public=$(cat /home/{{ ansible_hostname }}/tpcs-iac/demoboard/terraform/tp-iac.pub)
export TF_VAR_demoboard_aws_zones='["{{ student_tp_vars.tpiac.aws.region_for_apikey }}a","{{ student_tp_vars.tpiac.aws.region_for_apikey }}b","{{ student_tp_vars.tpiac.aws.region_for_apikey }}c"]'
