#!/usr/bin/env bash
set -euo pipefail

# Hidden helper for trainer-side TP IaC validation.
# It provisions demoboard with Terraform, deploys it with Ansible, then checks
# the frontend, monitor page, and API health endpoint through the frontend LB.

VM_NAME="{{ ansible_hostname }}"
WORKDIR="${TPIAC_WORKDIR:-$HOME/tpcs-iac}"
TF_DIR="$WORKDIR/demoboard/terraform"
ANSIBLE_DIR="$WORKDIR/demoboard/ansible"
VENV_DIR="${TPIAC_ANSIBLE_VENV:-$ANSIBLE_DIR/ansiblevenv}"
FRONT_SSH_HOST="${TPIAC_FRONT_SSH_HOST:-front1}"
LB_INVENTORY_HOST="${TPIAC_LB_INVENTORY_HOST:-front0}"
HTTP_TIMEOUT_SECONDS="${TPIAC_HTTP_TIMEOUT_SECONDS:-240}"

if [[ -n "${TPIAC_TERRAFORM_APPLY_ARGS+x}" ]]; then
  read -r -a TF_APPLY_ARGS <<< "$TPIAC_TERRAFORM_APPLY_ARGS"
else
  TF_APPLY_ARGS=(-auto-approve)
fi

require_path() {
  local path="$1"
  if [[ ! -e "$path" ]]; then
    echo "Missing required path: $path"
    exit 1
  fi
}

curl_retry() {
  local url="$1"
  local end_ts
  end_ts=$(( $(date +%s) + HTTP_TIMEOUT_SECONDS ))

  while true; do
    if curl -fsSL --max-time 10 "$url" >/dev/null; then
      break
    fi
    if [[ "$(date +%s)" -ge "$end_ts" ]]; then
      echo "Timeout waiting for $url"
      exit 1
    fi
    sleep 5
  done
}

host_json() {
  local host="$1"
  ansible-inventory -i aws_ec2.yml --host "$host"
}

get_host_field() {
  local host="$1"
  local jq_expr="$2"
  host_json "$host" | jq -r "$jq_expr"
}

require_path "$TF_DIR"
require_path "$ANSIBLE_DIR"

echo "== Terraform apply =="
cd "$TF_DIR"
terraform init
time terraform apply "${TF_APPLY_ARGS[@]}"

echo "== Ansible environment =="
cd "$ANSIBLE_DIR"
python3 -m venv "$VENV_DIR"
source "$VENV_DIR/bin/activate"
python -m pip install --upgrade pip
python -m pip install -r requirements.txt
ansible-galaxy collection install -r collections/requirements.yml

echo "== Dynamic inventory =="
ansible-inventory -i aws_ec2.yml --graph

echo "== SSH config update =="
FRONT_PUBLIC_IP="$(get_host_field "$FRONT_SSH_HOST" '.aws_public_ip_address // empty')"
if [[ -z "$FRONT_PUBLIC_IP" || "$FRONT_PUBLIC_IP" == "null" ]]; then
  FRONT_PUBLIC_IP="$(get_host_field front0 '.aws_public_ip_address // empty')"
fi
if [[ -z "$FRONT_PUBLIC_IP" || "$FRONT_PUBLIC_IP" == "null" ]]; then
  echo "Could not find a public IP for $FRONT_SSH_HOST or front0 in inventory"
  exit 1
fi
sed -i -E "s/[0-9]{1,3}(\.[0-9]{1,3}){3}/${FRONT_PUBLIC_IP}/g" ssh-config
echo "SSH ProxyJump public IP: $FRONT_PUBLIC_IP"

echo "== Ansible connectivity =="
ansible -i aws_ec2.yml all -m shell -a hostname

echo "== Demoboard deployment =="
time ansible-playbook -i aws_ec2.yml setup.yml -v

echo "== Load balancer checks =="
DNS_FRONT_LB="$(get_host_field "$LB_INVENTORY_HOST" '.aws_tags.front_lb_dns // empty')"
if [[ -z "$DNS_FRONT_LB" || "$DNS_FRONT_LB" == "null" ]]; then
  DNS_FRONT_LB="$(get_host_field "$FRONT_SSH_HOST" '.aws_tags.front_lb_dns // empty')"
fi
if [[ -z "$DNS_FRONT_LB" || "$DNS_FRONT_LB" == "null" ]]; then
  echo "Could not find front_lb_dns in inventory host tags"
  exit 1
fi

FRONT_URL="http://${DNS_FRONT_LB}"
echo "Waiting for frontend: $FRONT_URL/"
curl_retry "$FRONT_URL/"

echo "Waiting for monitor page: $FRONT_URL/monitor.html"
curl_retry "$FRONT_URL/monitor.html"

echo "Waiting for API health through frontend LB: $FRONT_URL/api/healthz"
curl_retry "$FRONT_URL/api/healthz"

echo
echo "Frontend headers:"
curl -fsSLI --max-time 10 "$FRONT_URL/" || true

echo
echo "API health:"
curl -fsSL --max-time 10 "$FRONT_URL/api/healthz"
echo

echo
echo "Monitor page samples:"
for i in 1 2 3 4 5; do
  echo "--- monitor sample $i ---"
  curl -fsSL --max-time 10 "$FRONT_URL/monitor.html" | sed -n '1,35p'
  sleep 1
done

echo
echo "TP IaC demoboard deploy test completed for $VM_NAME."
echo "Open in browser:"
echo "- $FRONT_URL/"
echo "- $FRONT_URL/monitor.html"
echo "- $FRONT_URL/api/healthz"
