{% set ssl_domains = access_docs_available_ssl_certificates | default([], true) %}
{% set access_ssl_enabled = acme_certificates_enable | bool and ('access' in ssl_domains) %}
{% set docs_ssl_enabled = acme_certificates_enable | bool and ('docs' in ssl_domains) %}
{% set monitoring_ssl_enabled = acme_certificates_enable | bool and ('monitoring' in ssl_domains) %}
{% set prometheus_ssl_enabled = acme_certificates_enable | bool and ('prometheus' in ssl_domains) %}
{% set grafana_ssl_enabled = acme_certificates_enable | bool and ('grafana' in ssl_domains) %}

server {
        listen 80 default_server;
        listen [::]:80 default_server;

        root /var/www/html;
        index index.php index.html index.htm index.nginx-debian.html;

        server_name access.{{ dns_subdomain }} www.access.{{ dns_subdomain }};
{% if access_ssl_enabled %}
        location /.well-known/acme-challenge/ {
                root /var/www/html;
        }
        location / {
                return 301 https://$host$request_uri;
        }
{% else %}
        location / {
                proxy_pass  https://127.0.0.1:8443;
                proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                proxy_set_header Host $host;
                proxy_http_version 1.1;
                proxy_set_header Upgrade $http_upgrade;
                proxy_set_header Connection "upgrade";
        }
{% endif %}
}

server {
        listen 80;
        listen [::]:80;

        server_name docs.{{ dns_subdomain }} www.docs.{{ dns_subdomain }};
{% if docs_ssl_enabled %}
        location /.well-known/acme-challenge/ {
                root /var/www/html/;
        }
        location / {
                return 301 https://$host$request_uri;
        }
{% else %}
        location /{
                root /var/www/html/;
                index index.php index.html;
                autoindex on;
                charset utf-8;
        }
        # pass PHP scripts on Nginx to FastCGI (PHP-FPM) server

        location ~ \.php$ {
                include snippets/fastcgi-php.conf;
                root /var/www/html/;
                # Nginx php-fpm sock config:
                fastcgi_pass unix:/run/php/php8.1-fpm.sock;
                # Nginx php-cgi config :
                # Nginx PHP fastcgi_pass 127.0.0.1:9000;
        }
        location /json/aws_ec2_metrics.prom {
                root /var/www/html/;
                default_type text/plain;
                add_header Content-Type "text/plain; version=0.0.4";
        }
{% endif %}
}

