{% if access_ssl_enabled %}
server {
        listen 443 ssl http2;
        listen [::]:443 ssl http2;

        server_name access.{{ dns_subdomain }} www.access.{{ dns_subdomain }};
        ssl_certificate /etc/letsencrypt/live/access.{{ dns_subdomain }}/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/access.{{ dns_subdomain }}/privkey.pem;

        location / {
                proxy_pass  https://127.0.0.1:8443;
                proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                proxy_set_header Host $host;
                proxy_http_version 1.1;
                proxy_set_header Upgrade $http_upgrade;
                proxy_set_header Connection "upgrade";
        }
}
{% endif %}

