<?php

function h($value) {
    return htmlspecialchars((string)($value ?? ''), ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8');
}

function getAwsRegion() {
    $token = trim(shell_exec("curl -sS --max-time 2 -X PUT http://169.254.169.254/latest/api/token -H 'X-aws-ec2-metadata-token-ttl-seconds: 60' 2>/dev/null") ?? '');
    if ($token !== '') {
        $az = trim(shell_exec("curl -sS --max-time 2 -H 'X-aws-ec2-metadata-token: {$token}' http://169.254.169.254/latest/meta-data/placement/availability-zone/ 2>/dev/null") ?? '');
        if ($az !== '') {
            return substr($az, 0, -1);
        }
    }

    $az = trim(shell_exec("curl -sS --max-time 2 http://169.254.169.254/latest/meta-data/placement/availability-zone/ 2>/dev/null") ?? '');
    if ($az !== '') {
        return substr($az, 0, -1);
    }

    $envRegion = getenv('AWS_REGION') ?: getenv('AWS_DEFAULT_REGION');
    if ($envRegion) {
        return trim($envRegion);
    }

    return trim(shell_exec("/usr/local/bin/aws configure get region 2>/dev/null || aws configure get region 2>/dev/null") ?? '');
}

$region = getAwsRegion();
$awsCli = is_executable('/usr/local/bin/aws') ? '/usr/local/bin/aws' : 'aws';

// Chargement du fichier JSON des correspondances utilisateur
$userMapping = json_decode(file_get_contents('/var/www/html/json/users.json'), true);

$availableTps = {{ access_docs_enabled_tp_names | to_json }};
$tptype = $argv[1] ?? ($_GET['tp'] ?? "{{ tp_name }}");
if (!in_array($tptype, $availableTps, true)) {
    $tptype = "{{ tp_name }}";
}
$dns_subdomain = "{{ dns_subdomain }}";

// Chargement du fichier JSON des clés d'API
if ($tptype == "tpiac") {
    $apiKeys = json_decode(file_get_contents('/var/www/html/json/api_keys.json'), true);
}

// Chargement des informations EKS mutualisées
$eksClusters = [];
$eksClustersFile = '/var/www/html/json/eks_clusters.json';
if (file_exists($eksClustersFile)) {
    $eksClustersRaw = json_decode(file_get_contents($eksClustersFile), true);
    if (is_array($eksClustersRaw)) {
        $eksClusters = $eksClustersRaw;
    }
}

// Chargement des informations ECR par VM (URL de repo uniquement)
$ecrRepos = [];
$ecrReposFile = '/var/www/html/json/ecr_repos.json';
if (file_exists($ecrReposFile)) {
    $ecrReposRaw = json_decode(file_get_contents($ecrReposFile), true);
    if (is_array($ecrReposRaw)) {
        $ecrRepos = $ecrReposRaw;
    }
}

$showEksClusters = in_array($tptype, ["tpkube", "tpmon"], true) && !empty($eksClusters);
$showEcrRepoColumn = $showEksClusters;

function resolveEksNodesByGroup($clusterName, $clusterData, $region) {
    global $awsCli;

    if (!isset($clusterData['node_group_names']) || !is_array($clusterData['node_group_names'])) {
        return "N/A";
    }

    $groupNodeLines = [];
    foreach ($clusterData['node_group_names'] as $nodeGroupName) {
        $clusterArg = escapeshellarg($clusterName);
        $groupArg = escapeshellarg($nodeGroupName);
        $regionArg = escapeshellarg($region);
        $awsCliArg = escapeshellcmd($awsCli);
        $cmd = "{$awsCliArg} ec2 describe-instances "
             . "--region {$regionArg} "
             . "--output text "
             . "--filters "
             . "Name=tag:eks:cluster-name,Values={$clusterArg} "
             . "Name=tag:eks:nodegroup-name,Values={$groupArg} "
             . "Name=instance-state-name,Values=pending,running,stopping,stopped "
             . "--query 'Reservations[].Instances[].PrivateDnsName'";
        $raw = trim(shell_exec($cmd) ?? '');
        if ($raw === '') {
            $groupNodeLines[] = "-";
            continue;
        }
        $nodes = preg_split('/\s+/', $raw);
        $nodes = array_values(array_filter($nodes));
        $groupNodeLines[] = !empty($nodes) ? implode(", ", $nodes) : "-";
    }

    return implode("<br/>", $groupNodeLines);
}

echo "<h1>TP type : " . h($tptype) . "</h1>";

if ($tptype == "tpiac") {
    echo "Votre nom d'utilisateur est unique pour tous les usages : user guacamole, user vm, user AWS console. Le mot de passe est identique au username (sauf pour console AWS cf. ci-dessous)</br>";
} else {
    echo "Votre nom d'utilisateur est unique pour tous les usages : user guacamole et user vm. Le mot de passe est identique au username.</br>";
}
echo "<i>Si besoin vous pouvez vous connectez directement à la vm (via SSH ou RDP) en utilisant le Record DNS (chercher la colonne).</i></br>";
echo "<i>  Exemple : ssh vmxx@vmxx.${dns_subdomain} (ou utiliser un client RDP)</i></br>";

if ($tptype == "tpiac") {
    echo "Les mots de passe pour console AWS et clé secrète d'API sont dans le fichier <b>/home/vmXX/tpcs-iac/.env</b> sur chacune de vos VMs</br></br>";
    echo "<h3><a href=\"https://tpiac.signin.aws.amazon.com/console/\" target=\"_blank\">Accès console AWS</a></h3>";
}

if ($showEksClusters) {
    echo "Les informations et kubeconfigs des clusters EKS mutualisés sont disponibles sur chaque VM étudiante dans <b>/home/vmXX/.kube/</b></br>";
}

echo "<h3><a href=\"https://access.${dns_subdomain}/\" target=\"_blank\">Accès Guacamole (bureau RDP pour votre VM)</a></h3>";


// En-tête du tableau HTML
echo "</br><h2>Liste des VMs étudiant(e)s</h2>";
echo "<table border='1'>
        <tr>
            <th>Nom réel</th>
            <th>Nom unique (username)</th>";
if ($tptype == "tpiac") {
    echo    "<th>Clé d'API (AK)</th>
            <th>Région où la clé d'API est active</th>";
}
echo        "<th>Adresse IP de la VM</th>
            <th>Record DNS</th>
            <th>Adresse IP du record DNS</th>
            <th>Statut de la VM</th>";
if ($showEcrRepoColumn) {
    echo    "<th>Repo ECR</th>";
}
echo        "
        </tr>";

// Parcourir le tableau de correspondance des utilisateurs
foreach ($userMapping as $user => $userData) {
    $UserRealName = $userData['name'];
    $apiKey = "N/A";
    $apiRegion = "N/A";
    if ($tptype == "tpiac") {
        $apiKey = isset($apiKeys[$user]['AK']) ? $apiKeys[$user]['AK'] : "N/A";
        $apiRegion = isset($apiKeys[$user]['Region']) ? $apiKeys[$user]['Region'] : "N/A";
    }

    // Exécuter la commande AWS CLI pour obtenir les détails de l'instance (we want all status except terminated/removed)
    $instanceName = 'vm' . substr($user, -2);
    $instanceDetails = [];
    $lookupStatus = "";
    if ($region === '') {
        $lookupStatus = "AWS region unavailable";
    } else {
        $regionArg = escapeshellarg($region);
        $instanceNameArg = escapeshellarg($instanceName);
        $awsCliArg = escapeshellcmd($awsCli);
        $cmd = "{$awsCliArg} ec2 describe-instances "
             . "--region {$regionArg} "
             . "--output json "
             . "--filters "
             . "Name=tag:Name,Values={$instanceNameArg} "
             . "Name=instance-state-name,Values=pending,running,shutting-down,stopping,stopped "
             . "--query 'Reservations[].Instances[].[InstanceId,PublicIpAddress,"
             . "Tags[?Key==`Name`]|[0].Value,"
             . "Tags[?Key==`AUTO_DNS_NAME`]|[0].Value,"
             . "State.Name]' 2>/tmp/vms-aws-{$instanceName}.err";
        $instanceOutput = shell_exec($cmd);
        $decodedInstanceDetails = json_decode($instanceOutput, true);
        if (is_array($decodedInstanceDetails)) {
            $instanceDetails = $decodedInstanceDetails;
        } else {
            $lookupStatus = "AWS lookup failed";
        }
    }

    if (empty($instanceDetails)) {
        echo "<tr>";
        echo "<td>" . h($UserRealName) . "</td>";
        echo "<td>" . h($instanceName) . "</td>";

        if ($tptype == "tpiac") {
            echo "<td>" . h($apiKey) . "</td>";
            echo "<td>" . h($apiRegion) . "</td>";
        }

        $status = $lookupStatus !== "" ? $lookupStatus : "Instance not found";
        echo "<td>N/A</td>";
        echo "<td>" . h($instanceName) . ".{$dns_subdomain}</td>";
        echo "<td>N/A</td>";
        echo "<td style='color:red;'>" . h($status) . "</td>";
        if ($showEcrRepoColumn) {
            $repoUrl = isset($ecrRepos[$user]['repository_url']) ? $ecrRepos[$user]['repository_url'] : "N/A";
            echo "<td style='max-width:50ch; width:50ch; white-space:normal; overflow-wrap:anywhere; word-break:break-word;'>" . h($repoUrl) . "</td>";
        }
        echo "</tr>";
        continue;
    }

    // Afficher les détails dans le tableau HTML
    foreach ($instanceDetails as $instance) {
        echo "<tr>";
        echo "<td>" . h($UserRealName) . "</td>";
        echo "<td>" . h($instance[2]) . "</td>";

        if ($tptype == "tpiac") {
            echo "<td>" . h($apiKey) . "</td>";
            echo "<td>" . h($apiRegion) . "</td>";
        }

        echo "<td>" . h($instance[1]) . "</td>";
        echo "<td>" . h($instance[2]) . ".{$dns_subdomain}</td>";

        // Exécuter un lookup pour obtenir l'adresse IP associée au record DNS
        $dnsNameArg = escapeshellarg("{$instance[2]}.{$dns_subdomain}");
        $dnsIpRaw = shell_exec("dig +short {$dnsNameArg} 2>&1");
        $dnsIp = trim($dnsIpRaw);
        // Nettoyer également l'EIP de AWS au cas où
        $expectedIp = trim($instance[1]);

        // Comparer l'IP DNS retournée à l'EIP attendue
        if ($dnsIp !== $expectedIp) {
            echo "<td style='color:red;'>" . h($dnsIp) . "</td>";
        } else {
            echo "<td>" . h($dnsIp) . "</td>";
        }

        if ($instance[4] !== "running") {
            echo "<td style='color:red;'>" . h($instance[4]) . "</td>";
        } else {
            echo "<td>" . h($instance[4]) . "</td>";
        }

        if ($showEcrRepoColumn) {
            $repoUrl = isset($ecrRepos[$user]['repository_url']) ? $ecrRepos[$user]['repository_url'] : "N/A";
            echo "<td style='max-width:50ch; width:50ch; white-space:normal; overflow-wrap:anywhere; word-break:break-word;'>" . h($repoUrl) . "</td>";
        }
        echo "</tr>";
    }
}

// Fermer le tableau HTML
echo "</table>";

if ($showEksClusters) {
    echo "</br></br></br><h2>Clusters EKS mutualisés</h2>";
    echo "<table border='1'>
            <tr>
                <th>Alias cluster</th>
                <th>Nom EKS</th>
                <th>Région</th>
                <th>Node groups</th>
                <th>Nodes</th>
                <th>Endpoint API (URL)</th>
            </tr>";

    foreach ($eksClusters as $clusterAlias => $clusterData) {
        $clusterName = isset($clusterData['cluster_name']) ? $clusterData['cluster_name'] : "N/A";
        $clusterRegion = isset($clusterData['region']) ? $clusterData['region'] : "N/A";
        $clusterEndpoint = isset($clusterData['endpoint']) ? $clusterData['endpoint'] : "N/A";
        $nodeGroups = "N/A";
        $nodesSummary = "N/A";
        if (isset($clusterData['node_group_names']) && is_array($clusterData['node_group_names'])) {
            $nodeGroups = implode("<br/>", $clusterData['node_group_names']);
            $nodesSummary = resolveEksNodesByGroup($clusterName, $clusterData, $clusterRegion);
        }

        echo "<tr>";
        echo "<td>{$clusterAlias}</td>";
        echo "<td>{$clusterName}</td>";
        echo "<td>{$clusterRegion}</td>";
        echo "<td style='max-width:26ch; width:26ch; white-space:normal; overflow-wrap:anywhere; word-break:break-word;'>{$nodeGroups}</td>";
        echo "<td style='max-width:42ch; width:42ch; white-space:normal; overflow-wrap:anywhere; word-break:break-word;'>{$nodesSummary}</td>";
        echo "<td>{$clusterEndpoint}</td>";
        echo "</tr>";
    }

    echo "</table>";
}

?>
